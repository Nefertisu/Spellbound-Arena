{
  "name": "spellbound-arena",
  "private": true,
  "workspaces": [
    "packages/*",
    "client",
    "server"
  ],
  "scripts": {
    "start:server": "npm run start:dev --prefix server",
    "start:client": "npm run dev --prefix client",
    "start:all": "concurrently -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run start:server\" \"npm run start:client\"",
    "typecheck:shared": "npm run typecheck --prefix packages/shared",
    "docker:db": "docker compose up -d postgres",
    "docker:db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --prefix server",
    "db:studio": "npm run prisma:studio --prefix server"
  },
  "devDependencies": {
    "concurrently": "10.0.3"
  }
}
