generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int           @id @default(autoincrement())
  email               String        @unique
  name                String
  password            String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  selectedCharacterId Int?
  characters          Character[]
  lobbyMember         LobbyMember[]
  selectedCharacter   Character?    @relation("SelectedCharacter", fields: [selectedCharacterId], references: [id])
}

model Character {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  userId     Int
  attributes Attributes?
  user       User        @relation(fields: [userId], references: [id])
  selectedBy User[]      @relation("SelectedCharacter")
}

model Attributes {
  id               Int       @id @default(autoincrement())
  strength         Int       @default(0)
  agility          Int       @default(0)
  intelligence     Int       @default(0)
  statusResistance Int       @default(0)
  characterId      Int       @unique
  fury             Int       @default(0)
  pushResistance   Int       @default(0)
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Lobby {
  id          Int          @id @default(autoincrement())
  lobbyStatus LobbyStatus
  mode        LobbyMode
  createdAt   DateTime     @default(now())
  members     LobbyMember?
}

model LobbyMember {
  id      Int     @unique
  isBot   Boolean
  slot    Int
  userId  Int?
  lobbyId Int     @unique @default(autoincrement())
  lobby   Lobby   @relation(fields: [lobbyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

enum LobbyMode {
  ONE_VS_ONE
  TWO_VS_TWO
  THREE_VS_THREE
}

enum LobbyStatus {
  WAITING
  READY
  IN_GAME
  FINISHED
  CANCELLED
}
